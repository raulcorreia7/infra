# Runtime noise
*.log
*.pid
.DS_Store

# Host-local environment files
hosts/*/.env
!hosts/*/.env.example

# Generated stack state
stacks/**/data/**
!stacks/**/data/.gitkeep
!stacks/**/data/**/.gitkeep

# Copied local config
stacks/**/.env
stacks/**/config/Caddyfile
stacks/**/config/policy.yaml
stacks/**/config/**/config.yaml

# Runtime databases and keys
stacks/**/*.local
stacks/**/*.db
stacks/**/*.sqlite
stacks/**/*.sqlite3
stacks/**/*.pem
stacks/**/*.key
stacks/**/*.crt
