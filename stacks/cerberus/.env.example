HOST_NAME=cerberus
PUBLIC_FQDN=tailscale.cerberus.raulcorreia.dev
TAILNET_DOMAIN=tailnet.cerberus.raulcorreia.dev
HOME_DOMAIN=home.arpa
HOME_DNS_RESOLVER=192.168.100.1
TZ=Europe/Amsterdam
EDGE_NETWORK=edge

# Optional: keep this set if you want a stable Headplane cookie secret.
# HEADPLANE_COOKIE_SECRET=

# Optional: comma-separated Headscale users to create after startup.
HEADSCALE_SEED_USERS=gil,raul

# If HEADPLANE_COOKIE_SECRET is left unset, `./bin/setup.sh cerberus` will
# generate it on first render.
