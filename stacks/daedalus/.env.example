HOST_NAME=daedalus
DAEDALUS_HOST=daedalus.home.arpa
HOME_DOMAIN=home.arpa
TZ=Europe/Amsterdam
EDGE_NETWORK=edge

# Reverse proxy hostnames
KOMODO_HOST=komodo.home.arpa
FORGEJO_HOST=forgejo.home.arpa
FORGEJO_SSH_HOST=forgejo.home.arpa
FORGEJO_SSH_PORT=2222
HOMEPAGE_HOST=homepage.home.arpa

# Komodo
KOMODO_DB_USERNAME=komodo
KOMODO_DB_PASSWORD=change-me-komodo-db-password
KOMODO_PASSKEY=change-me-komodo-passkey
KOMODO_WEBHOOK_SECRET=change-me-komodo-webhook-secret
KOMODO_JWT_SECRET=change-me-komodo-jwt-secret
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=change-me-komodo-admin-password

# Forgejo
FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_SECRET_KEY=change-me-forgejo-secret-key
FORGEJO_INTERNAL_TOKEN=change-me-forgejo-internal-token
FORGEJO_JWT_SECRET=change-me-forgejo-jwt-secret
FORGEJO_LFS_JWT_SECRET=change-me-forgejo-lfs-jwt-secret

# Any value left as `change-me-*` will be replaced with a generated secret by
# `./bin/setup.sh daedalus` the first time it runs against a real `.env` file.
