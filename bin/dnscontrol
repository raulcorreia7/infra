#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
BINARY_PATH="${ROOT_DIR}/tools/dnscontrol/dnscontrol"
DNS_DIR="${ROOT_DIR}/dns"

if [[ ! -x "$BINARY_PATH" ]]; then
	printf 'error: missing %s; run ./bin/install-dnscontrol.sh first\n' "${BINARY_PATH#"${ROOT_DIR}/"}" >&2
	exit 1
fi

if [[ -f "${DNS_DIR}/.env" ]]; then
	set -a
	# shellcheck disable=SC1091
	. "${DNS_DIR}/.env"
	set +a
fi

cd -- "$DNS_DIR"
exec "$BINARY_PATH" "$@"
